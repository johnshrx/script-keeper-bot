# Token del bot (Discord Developer Portal -> tu app -> Bot -> Reset Token)
DISCORD_TOKEN=tu_token_aqui

# Application ID (Discord Developer Portal -> tu app -> General Information -> Application ID)
CLIENT_ID=tu_application_id_aqui

# (Opcional) Si lo defines, los slash commands se registran SOLO en ese servidor (instantáneo).
# Si lo dejas vacío, se registran globalmente (puede tardar hasta 1 hora en propagar).
GUILD_ID=

# Tu user ID de Discord. Solo este usuario puede usar /allow y /revoke.
OWNER_ID=tu_user_id_aqui
